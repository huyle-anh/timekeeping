# Copy this file to .env and fill in real values before running in production.

# Database file path
DATABASE_URL=timekeeping.db

# Server listen address
BIND_ADDR=0.0.0.0:3001

# Connection pool size
DB_POOL_SIZE=10

# !! CHANGE THESE IN PRODUCTION !!
JWT_SECRET=timekeeping-secret-key-change-in-production
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Allowed CORS origin (must match your frontend URL)
CORS_ALLOWED_ORIGIN=http://localhost:5173

# Max attendance check-in/out requests per employee per minute
RATE_LIMIT_PER_MINUTE=30
